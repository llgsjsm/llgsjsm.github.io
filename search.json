---
---
[
  {% for post in site.posts %}
    {
      "title"    : {{ post.title | jsonify }},
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "category" : "{{ post.categories | join: ', ' }}",
      "date"     : "{{ post.date | date: "%B %e, %Y" }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
